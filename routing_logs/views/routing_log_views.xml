<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_routing_log_tree" model="ir.ui.view">
            <field name="name">routing.log.tree</field>
            <field name="model">routing.log</field>
            <field name="arch" type="xml">
                <tree string="Routing Logs" create="0" edit="0" delete="0">
                    <field name="changed_by" string="Changed By"/>
                    <field name="changed_date" string="Date &amp; Time"/>
                    <field name="field_name" string="Field"/>
                    <field name="old_value" string="Old Value"/>
                    <field name="new_value" string="New Value"/>
                    <field name="model_id" optional="hide"/>
                    <field name="res_id" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="view_routing_log_form" model="ir.ui.view">
            <field name="name">routing.log.form</field>
            <field name="model">routing.log</field>
            <field name="arch" type="xml">
                <form string="Routing Log" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="model_id" readonly="1"/>
                                <field name="res_id" readonly="1"/>
                                <field name="field_name" readonly="1"/>
                            </group>
                            <group>
                                <field name="changed_by" readonly="1"/>
                                <field name="changed_date" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="old_value" readonly="1"/>
                            <field name="new_value" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="routing_log_rule_user_read_scope" model="ir.rule">
            <field name="name">Routing Log - readable target records only</field>
            <field name="model_id" ref="model_routing_log"/>
            <field name="domain_force">[('id', 'in', user._routing_log_allowed_ids())]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


        <record id="view_mrp_routing_form_routing_logs" model="ir.ui.view">
            <field name="name">mrp.routing.form.routing.logs</field>
            <field name="model">mrp.routing</field>
            <field name="inherit_id" ref="mrp.mrp_routing_form_view"/>
            <field name="arch" type="xml">
            
                <xpath expr="//sheet" position="after">
                    <div class="o_form_sheet_bg">
                        <sheet>
                            <div class="oe_title">
                                <h2>Audit Trail</h2>
                            </div>

                            <div class="oe_chatter">
                                <field name="message_ids" widget="mail_thread"/>
                            </div>
                        </sheet>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="view_mrp_operations_form_routing_logs" model="ir.ui.view">
            <field name="name">mrp.operations.form.routing.logs</field>
            <field name="model">mrp.operations</field>
            <field name="arch" type="xml">
                <form string="Operations">
                    <sheet>
                        <group>
                            <field name="operation_name"/>
                            <field name="is_yield"/>
                            <field name="combined"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_mrp_operations_form_routing_logs_inherit" model="ir.ui.view">
            <field name="name">mrp.operations.form.routing.logs.inherit</field>
            <field name="model">mrp.operations</field>
            <field name="inherit_id" ref="view_mrp_operations_form_routing_logs"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="after">
                    <div class="o_form_sheet_bg">
                        <sheet>
                            <div class="oe_title">
                                <h2>Audit Trail</h2>
                            </div>
                            <field name="routing_log_timeline_html" widget="html" readonly="1"/>
                        </sheet>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>