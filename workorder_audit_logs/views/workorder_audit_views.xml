<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_mrp_workorder_audit_log_tree" model="ir.ui.view">
            <field name="name">mrp.workorder.audit.log.tree</field>
            <field name="model">mrp.workorder.audit.log</field>
            <field name="arch" type="xml">
                <tree string="Work Order Audit Logs" create="0" edit="0" delete="0">
                    <field name="changed_date" string="Date &amp; Time"/>
                    <field name="changed_by" string="Changed By"/>
                    <field name="field_name" string="Field"/>
                    <field name="old_value" string="Old Value"/>
                    <field name="new_value" string="New Value"/>
                    <field name="model_id" optional="hide"/>
                    <field name="res_id" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="view_mrp_workorder_audit_log_form" model="ir.ui.view">
            <field name="name">mrp.workorder.audit.log.form</field>
            <field name="model">mrp.workorder.audit.log</field>
            <field name="arch" type="xml">
                <form string="Work Order Audit Log" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="model_id" readonly="1"/>
                                <field name="res_id" readonly="1"/>
                                <field name="field_name" readonly="1"/>
                            </group>
                            <group>
                                <field name="changed_by" readonly="1"/>
                                <field name="changed_date" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="old_value" readonly="1"/>
                            <field name="new_value" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="mrp_workorder_audit_log_rule_user_read_scope" model="ir.rule">
            <field name="name">MRP Work Order Audit Log - readable target records only</field>
            <field name="model_id" ref="model_mrp_workorder_audit_log"/>
            <field name="domain_force">[('id', 'in', user._workorder_audit_log_allowed_ids())]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="view_mrp_workorder_form_inherit_audit_pdf_button" model="ir.ui.view">
            <field name="name">mrp.workorder.form.inherit.audit.pdf.button</field>
            <field name="model">mrp.workorder</field>
            <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_print_workorder_audit_pdf"
                            type="object"
                            string="Audit PDF"
                            class="btn-secondary"
                            icon="fa-file-pdf-o"/>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_print_workorder_audit_pdf"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-pdf-o"
                            string="Audit PDF"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
