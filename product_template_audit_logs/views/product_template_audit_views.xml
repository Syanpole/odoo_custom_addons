<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_template_form_inherit_audit_pdf_button" model="ir.ui.view">
            <field name="name">product.template.form.inherit.audit.pdf.button</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_print_product_template_audit_pdf"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-pdf-o"
                            string="Audit PDF"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
