<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <report
            id="report_lot_audit_pdf"
            model="stock.production.lot"
            string="Lot Number Audit Report - PDF"
            name="lot_number_logs.lot_audit"
            file="lot_number_logs"
            report_type="qweb-pdf"/>

        <record id="report_lot_audit_pdf" model="ir.actions.report">
            <field name="attachment_use" eval="False"/>
            <field name="attachment" eval="False"/>
        </record>

        <template id="lot_audit">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="lot" t-value="doc['lot']"/>
                    <t t-set="audit_logs" t-value="doc['audit_logs']"/>
                    <t t-set="module_field_rows" t-value="doc['module_field_rows']"/>
                    <t t-set="logo_base64" t-value="doc['logo_base64']"/>
                    <t t-set="company_name" t-value="doc['company_name']"/>

                    <div class="article o_report_layout_standard">
                        <div class="page" style="position: relative; font-family: Arial; line-height: 1.35;">
                            <div style="position: relative; margin-bottom: 24px;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr style="border-bottom: 2px solid #333;">
                                        <td style="width: 25%; text-align: center; vertical-align: middle; padding-bottom: 10px;">
                                            <t t-if="logo_base64">
                                                <img t-att-src="'data:image/png;base64,%s' % logo_base64" style="max-height: 70px; max-width: 100%;"/>
                                            </t>
                                        </td>
                                        <td style="width: 50%; padding-bottom: 10px;"></td>
                                        <td style="width: 25%; text-align: right; vertical-align: middle; padding-right: 10px; padding-bottom: 10px;">
                                            <div style="font-size: 16px; font-weight: bold;"><t t-esc="company_name"/></div>
                                            <div style="font-size: 12px; color: #666;">Lot Number Audit Report</div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="width: 33%; padding: 7px 0;"><strong>Lot ID:</strong> <t t-esc="lot.id"/></td>
                                        <td style="width: 33%; padding: 7px 0;"><strong>Lot/Serial Number:</strong> <t t-esc="lot.name or 'N/A'"/></td>
                                        <td style="width: 33%; padding: 7px 0;"><strong>Printed Date:</strong> <t t-esc="printed_date"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 7px 0;"><strong>Product:</strong> <t t-esc="lot.product_id.display_name if lot.product_id else 'N/A'"/></td>
                                        <td style="padding: 7px 0;"><strong>Internal Reference:</strong> <t t-esc="lot.ref or 'N/A'"/></td>
                                        <td style="padding: 7px 0;"><strong>Active:</strong> <t t-esc="'Yes' if ('active' in lot._fields and lot.active) else ('No' if 'active' in lot._fields else 'N/A')"/></td>
                                    </tr>
                                </table>
                            </div>

                            <div style="position: relative; margin-bottom: 24px;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr>
                                        <td style="width: 33%; padding: 7px 0;"><strong>Quantity:</strong> <t t-esc="lot.product_qty or 0.0"/></td>
                                        <td style="width: 33%; padding: 7px 0;"><strong>Unit of Measure:</strong> <t t-esc="lot.product_uom_id.display_name if lot.product_uom_id else 'N/A'"/></td>
                                        <td style="width: 33%; padding: 7px 0;"><strong>Company:</strong> <t t-esc="lot.company_id.display_name if lot.company_id else 'N/A'"/></td>
                                    </tr>
                                </table>
                            </div>

                            <div style="position: relative; margin-bottom: 28px;">
                                <table style="width: 100%; border-collapse: separate; border-spacing: 0 3px; table-layout: fixed;">
                                    <tbody>
                                        <t t-foreach="module_field_rows" t-as="field_row">
                                            <tr>
                                                <t t-foreach="field_row" t-as="field_item">
                                                    <td style="width: 33%; padding: 3px 10px 3px 0; vertical-align: top;">
                                                        <t t-if="field_item['label']">
                                                            <strong><t t-esc="field_item['label']"/>:</strong>
                                                            <span style="margin-left: 2px;"><t t-esc="field_item['value']"/></span>
                                                        </t>
                                                    </td>
                                                </t>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>

                            <div style="position: relative;">
                                <h4 style="font-weight: bold; margin: 16px 0 12px 0; font-size: 24px;">Audit Logs</h4>
                                <t t-if="audit_logs">
                                    <table style="width: 100%; border-collapse: collapse; font-size: 13px; table-layout: fixed;">
                                        <thead>
                                            <tr style="background-color: #f0f0f0; font-weight: bold; border-bottom: 2px solid #333;">
                                                <th style="padding: 8px; text-align: left; width: 18%;">Changed On</th>
                                                <th style="padding: 8px; text-align: left; width: 18%;">Field</th>
                                                <th style="padding: 8px; text-align: left; width: 22%;">Old Value</th>
                                                <th style="padding: 8px; text-align: left; width: 28%;">New Value</th>
                                                <th style="padding: 8px; text-align: left; width: 14%;">Changed By</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="audit_logs" t-as="log">
                                                <tr style="border-bottom: 1px solid #ddd; vertical-align: top;">
                                                    <td style="padding: 7px 8px;"><t t-esc="log.changed_date.strftime('%Y-%m-%d %H:%M:%S') if log.changed_date else 'N/A'"/></td>
                                                    <td style="padding: 7px 8px; word-wrap: break-word;"><t t-esc="log.field_name"/></td>
                                                    <td style="padding: 7px 8px; word-wrap: break-word;"><t t-esc="log.old_value or 'N/A'"/></td>
                                                    <td style="padding: 7px 8px; word-wrap: break-word;"><t t-esc="log.new_value or 'N/A'"/></td>
                                                    <td style="padding: 7px 8px; word-wrap: break-word;"><t t-esc="log.changed_by.display_name"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <p style="margin: 10px 0; font-size: 12px;"><em>No audit logs recorded yet for this lot number.</em></p>
                                </t>
                            </div>

                            <div style="position: absolute; top: 0; right: 0; bottom: 0; left: 0; z-index: 10000; pointer-events: none;">
                                <div style="position: absolute; top: 50%; left: 50%; white-space: nowrap; -webkit-transform: translate(-50%, -50%) rotate(-45deg); transform: translate(-50%, -50%) rotate(-45deg); -webkit-transform-origin: center; transform-origin: center;">
                                    <span style="display: inline-block; color: #B3B3B3; opacity: 0.5; font-family: 'Helvetica Neue', 'Liberation Sans', Arial, sans-serif; font-weight: 700; font-size: 64px; letter-spacing: 1px; line-height: 1; margin: 0; padding: 0; user-select: text; -webkit-user-select: text;">TEAM PACIFIC CORPORATION</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
