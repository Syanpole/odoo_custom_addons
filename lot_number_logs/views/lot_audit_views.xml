<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_production_lot_form_inherit_audit_pdf_button" model="ir.ui.view">
            <field name="name">stock.production.lot.form.inherit.audit.pdf.button</field>
            <field name="model">stock.production.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_print_lot_audit_pdf"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-pdf-o"
                            string="Audit PDF"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
