<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_product_form_inherit_audit_pdf_button" model="ir.ui.view">
            <field name="name">product.product.form.inherit.audit.pdf.button</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_print_product_audit_pdf"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-pdf-o"
                            string="Audit PDF"/>
                </xpath>
            </field>
        </record>

        <record id="view_product_variant_easy_edit_inherit_audit_pdf_button" model="ir.ui.view">
            <field name="name">product.product.easy.form.inherit.audit.pdf.button</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_print_product_audit_pdf"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-pdf-o"
                            string="Audit PDF"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
